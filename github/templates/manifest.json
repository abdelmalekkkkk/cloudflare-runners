{
  "name": "Cloudflare Runners",
  "url": "https://mloki.dev",
  "hook_attributes": {
    "url": "{{.WebhookURL}}",
    "active": true
  },
  "redirect_url": "{{.RedirectURL}}",
  "description": "Run Github Workflows on Cloudflare Containers",
  "public": false,
  "default_permissions": {
    "actions": "write",
    "administration": "write",
    "metadata": "read"
  },
  "default_events": ["workflow_job", "workflow_run"]
}
